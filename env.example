# ── Option A: OpenAI (direct) ──────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ── Option B: Azure OpenAI ─────────────────────────────────────────────────
# If AZURE_OPENAI_ENDPOINT is set, Azure takes priority over OPENAI_API_KEY.
#
# 1. portal.azure.com → Create resource → "Azure OpenAI"
# 2. Resource → Keys and Endpoint → copy Key 1 and Endpoint
# 3. Azure AI Foundry (oai.azure.com) → Deployments → Deploy gpt-4o-mini
#    Copy the deployment name you gave it.
#
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2025-01-01-preview   # optional, this is the default

# ── Azure grounded mode (optional) ────────────────────────────────────────
# Enables live Bing web search in --mode grounded / both.
# portal.azure.com → Create resource → "Bing Search v7"
# Resource → Keys → copy Key 1
#
# BING_SEARCH_KEY=your-bing-search-key-here
# BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/
